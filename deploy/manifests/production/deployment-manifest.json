  "runtime": {
    "control_plane": "nodejs22",
    "realtime_plane": "go1.23",
    "engine_plane": "python3.11"
  },
  "services": [
    {
      "name": "api-gateway",
      "kind": "control-plane",
      "runtime": "nodejs22",
      "entrypoint": "pnpm --filter api-gateway start",
      "port": 8080,
      "scaling": {
        "min_replicas": 2,
        "max_replicas": 6
      },
      "resources": {
        "cpu": "500m",
        "memory": "512Mi"
      }
    },
    {
      "name": "bff-console",
      "kind": "control-plane",
      "runtime": "nodejs22",
      "entrypoint": "pnpm --filter bff-console start",
      "port": 8081,
      "scaling": {
        "min_replicas": 2,
        "max_replicas": 4
      },
      "resources": {
        "cpu": "500m",
        "memory": "512Mi"
      }
    },
    {
      "name": "billing-service",
      "kind": "control-plane",
      "runtime": "nodejs22",
      "entrypoint": "pnpm --filter billing-service start",
      "port": 8082,
      "scaling": {
        "min_replicas": 2,
        "max_replicas": 4
      },
      "resources": {
        "cpu": "500m",
        "memory": "512Mi"
      }
    },
    {
      "name": "liveops-service",
      "kind": "business-plane",
      "runtime": "nodejs22",
      "entrypoint": "pnpm --filter liveops-service start",
      "port": 8083,
      "scaling": {
        "min_replicas": 2,
        "max_replicas": 4
      },
      "resources": {
        "cpu": "750m",
        "memory": "768Mi"
      }
    },
    {
      "name": "media-gateway",
      "kind": "realtime-plane",
      "runtime": "go1.23",
      "entrypoint": "./media-gateway",
      "port": 9000,
      "scaling": {
        "min_replicas": 2,
        "max_replicas": 6
      },
      "resources": {
        "cpu": "1000m",
        "memory": "1Gi"
      }
    },
    {
      "name": "avatar-render-service",
      "kind": "engine-plane",
      "runtime": "python3.11",
      "entrypoint": "uvicorn app.main:app --host 0.0.0.0 --port 7000",
      "port": 7000,
      "scaling": {
        "min_replicas": 1,
        "max_replicas": 3
      },
      "resources": {
        "cpu": "2000m",
        "memory": "4Gi",
        "gpu": "1"
      }
    }
  ],
  "dependencies": [
    {
      "name": "postgresql16",
