  "stage_model": {
    "current": "stage_4_productionization",
    "allowed_values": [
      "stage_1_platform_foundation",
      "stage_2_adapter_enablement",
      "stage_3_console_and_director",
      "stage_4_productionization"
    ],
    "release_policy": {
      "stage_1_platform_foundation": {
        "allowed_environments": [
          "local_development"
        ],
        "production_manifest_allowed": false
      },
      "stage_2_adapter_enablement": {
        "allowed_environments": [
          "local_development",
          "single_gpu_validation"
        ],
        "production_manifest_allowed": false
      },
      "stage_3_console_and_director": {
        "allowed_environments": [
          "local_development",
          "single_gpu_validation"
        ],
        "production_manifest_allowed": false
      },
      "stage_4_productionization": {
        "allowed_environments": [
          "local_development",
          "single_gpu_validation",
          "cloud_production"
        ],
        "production_manifest_allowed": true
      }
    }
  },
  "environment_model": {
    "current": "cloud_production",
    "allowed_values": [
      "local_development",
      "single_gpu_validation",
      "cloud_production"
    ],
    "topology": {
      "local_development": "docker_compose_control_plane",
      "single_gpu_validation": "single_gpu_workstation_validation",
      "cloud_production": "kubernetes_cpu_gpu_split_with_cloudflare"
    }
  },
  "governance": {
    "public_api_prefix": "/api/v1",
    "allowed_plans": [
      "free_trial",
      "professional",
      "enterprise"
    ],
    "billing_truth_source_service": "billing-service",
    "frontend_open_source_direct_access_allowed": false
